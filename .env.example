# Optional. Without a key, LandLens leaves population trend unavailable rather
# than substituting a modeled value. Request a free key from the U.S. Census API.
VITE_CENSUS_API_KEY=

# Optional in local development; required in production to route public GIS
# traffic through the hardened cache/proxy in server/data-proxy.mjs.
# VITE_DATA_PROXY_URL=http://localhost:8787/api/data
